import "babylonjs";
import "babylonjs-loaders";
// CDN読み込みの場合はindex.htmlでscriptタグを追加してください
// ここではLGraphがwindowに存在することを前提にします

const canvas3d = document.getElementById("canvas3d");
const engine = new BABYLON.Engine(canvas3d, true);
const scene = new BABYLON.Scene(engine);
scene.enablePhysics(new BABYLON.Vector3(0, -9.81, 0), new BABYLON.CannonJSPlugin());

const camera = new BABYLON.ArcRotateCamera("cam", 0, 1, 10, BABYLON.Vector3.Zero(), scene);
camera.attachControl(canvas3d, true);
new BABYLON.HemisphericLight("light", new BABYLON.Vector3(0,1,0), scene);

// 地面
const ground = BABYLON.MeshBuilder.CreateGround("ground", {width: 10, height: 10}, scene);
ground.physicsImpostor = new BABYLON.PhysicsImpostor(ground, BABYLON.PhysicsImpostor.BoxImpostor, {mass: 0}, scene);

engine.runRenderLoop(() => scene.render());

// LiteGraphの初期化
const graph = new LGraph();
const canvasGraph = new LGraphCanvas("#canvasGraph", graph);

// 実行ノードの実装
function ExecNode() {
    this.addInput("Settings", "object");
    this.addWidget("button", "▶️ Run", null, () => {
        const box = BABYLON.MeshBuilder.CreateBox("box", {size: 1}, scene);
        box.position.y = 5;
        box.physicsImpostor = new BABYLON.PhysicsImpostor(box, BABYLON.PhysicsImpostor.BoxImpostor, {mass: 1}, scene);
    });
}
LiteGraph.registerNodeType("game/execute", ExecNode);

const node = LiteGraph.createNode("game/execute");
node.pos = [100, 100];
graph.add(node);
graph.start();

// リサイズ対応
window.addEventListener("resize", () => {
    engine.resize();
    canvasGraph.resize();
});
